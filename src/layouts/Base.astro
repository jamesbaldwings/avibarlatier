---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.js';

const {
  title,
  description = site.description,
  image = '/img/og-default.png',
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} — ${site.name}` : site.title;
const canonical = new URL(Astro.url.pathname, site.url).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, site.url).href} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Person schema for SEO -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Aviceen Barlatier',
      alternateName: ['Avi Barlatier', 'Aviceen'],
      url: site.url,
      jobTitle: 'Author, Leadership Educator, Technology Leader',
      knowsAbout: ['Leadership development', 'People management', 'Human-centered AI', 'Cybersecurity', 'Workplace culture'],
    })} />

    <!-- Mark JS active before paint so .reveal only hides when JS can un-hide it -->
    <script is:inline>document.documentElement.classList.add('js');</script>

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="sr-only">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll reveal — progressive enhancement, respects reduced motion.
      const els = document.querySelectorAll('.reveal');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (els.length && 'IntersectionObserver' in window && !reduce) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach((el) => io.observe(el));
        // Fallback: anything still hidden once everything has loaded gets shown.
        window.addEventListener('load', () => {
          setTimeout(() => els.forEach((el) => el.classList.add('in')), 1200);
        });
      } else {
        els.forEach((el) => el.classList.add('in'));
      }
    </script>
  </body>
</html>
