---
// Horizontal, scroll-snapping carousel of the latest YouTube uploads.
// Pass `videos` from getChannelVideos() (src/lib/youtube.js). Renders nothing
// when there are no videos, so callers can show their own fallback.
import { links } from '../data/site.js';

const { videos = [], eyebrow = 'From the channel', title = 'Latest videos' } = Astro.props;
const channelUrl = links.youtube;
---
{videos.length > 0 && (
  <section class="yt section reveal">
    <div class="wrap">
      <div class="yt-head">
        <div>
          <p class="eyebrow">{eyebrow}</p>
          <h2>{title}</h2>
        </div>
        <div class="yt-controls">
          {channelUrl && (
            <a href={channelUrl} class="row-link" target="_blank" rel="noopener">Visit the channel →</a>
          )}
          <div class="yt-arrows" aria-hidden="true">
            <button type="button" class="yt-arrow" data-dir="-1" aria-label="Scroll left">‹</button>
            <button type="button" class="yt-arrow" data-dir="1" aria-label="Scroll right">›</button>
          </div>
        </div>
      </div>

      <ul class="yt-track" data-track>
        {videos.map((v) => (
          <li class="yt-item">
            <a href={v.url} target="_blank" rel="noopener" class="yt-card" aria-label={`Watch: ${v.title}`}>
              <div class="yt-thumb">
                <img src={v.thumbnail} alt="" loading="lazy" width="480" height="360" />
                <span class="yt-play" aria-hidden="true">▶</span>
              </div>
              <h3 class="yt-title">{v.title}</h3>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}

<script>
  document.querySelectorAll('.yt').forEach((section) => {
    const track = section.querySelector('[data-track]');
    if (!track) return;
    section.querySelectorAll('.yt-arrow').forEach((btn) => {
      btn.addEventListener('click', () => {
        const dir = Number(btn.getAttribute('data-dir')) || 1;
        track.scrollBy({ left: dir * Math.min(track.clientWidth * 0.8, 600), behavior: 'smooth' });
      });
    });
  });
</script>

<style>
  .yt { background: var(--paper-pure); border-block: 1px solid var(--cream-line); }
  .yt-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.8rem; }
  .yt-head h2 { font-size: var(--step-2); }
  .yt-controls { display: flex; align-items: center; gap: 1.2rem; }
  .row-link { font-weight: 600; text-decoration: none; white-space: nowrap; }
  .yt-arrows { display: none; gap: 0.4rem; }
  .yt-arrow {
    width: 2.4rem; height: 2.4rem; border-radius: 50%; cursor: pointer;
    border: 1px solid var(--cream-line); background: var(--paper);
    font-size: 1.3rem; line-height: 1; color: var(--ink); display: grid; place-content: center;
    transition: border-color 0.15s, background 0.15s;
  }
  .yt-arrow:hover { border-color: var(--brass); background: color-mix(in srgb, var(--brass) 12%, transparent); }

  .yt-track {
    list-style: none; margin: 0; padding: 0 0 0.5rem;
    display: grid; grid-auto-flow: column;
    grid-auto-columns: 78%;
    gap: 1.2rem; overflow-x: auto; scroll-snap-type: x mandatory;
    scrollbar-width: thin;
  }
  .yt-item { scroll-snap-align: start; }
  .yt-card { display: block; text-decoration: none; color: inherit; }
  .yt-thumb {
    position: relative; aspect-ratio: 16/9; overflow: hidden;
    border-radius: var(--radius); background: var(--ink);
    box-shadow: 0 12px 30px -18px rgba(22,32,46,0.5); transition: transform 0.2s;
  }
  .yt-card:hover .yt-thumb { transform: translateY(-3px); }
  .yt-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .yt-play {
    position: absolute; inset: 0; margin: auto; width: 3rem; height: 3rem;
    display: grid; place-content: center; padding-left: 3px;
    background: color-mix(in srgb, var(--ink) 78%, transparent); color: var(--paper);
    border-radius: 50%; font-size: 1rem;
  }
  .yt-title { font-size: 1rem; margin: 0.7rem 0 0; line-height: 1.25; color: var(--ink); }

  @media (min-width: 640px) { .yt-track { grid-auto-columns: 42%; } }
  @media (min-width: 960px) {
    .yt-track { grid-auto-columns: 30%; }
    .yt-arrows { display: flex; }
  }
</style>
