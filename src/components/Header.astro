---
import { nav, site } from '../data/site.js';
const path = Astro.url.pathname;
// Hide links to pages an admin has unpublished (helper set in src/middleware.js).
const isPublished = Astro.locals.isPublished ?? (() => true);
const visibleNav = nav.filter((item) => isPublished(item.href));
---
<header class="hdr">
  <div class="wrap hdr-inner">
    <a href="/" class="brand" aria-label="Avi Barlatier — home">
      <span class="brand-mark">AB</span>
      <span class="brand-name">Avi&nbsp;Barlatier</span>
    </a>

    <nav class="nav-desktop" aria-label="Primary">
      {visibleNav.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: path === item.href }]}
        >{item.label}</a>
      ))}
    </nav>

    <details class="nav-mobile">
      <summary aria-label="Menu">
        <span></span><span></span><span></span>
      </summary>
      <div class="nav-mobile-panel">
        {visibleNav.map((item) => (
          <a href={item.href} class:list={['nav-link', { active: path === item.href }]}>{item.label}</a>
        ))}
      </div>
    </details>
  </div>
</header>

<style>
  .hdr {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--cream-line);
  }
  .hdr-inner { display: flex; align-items: center; justify-content: space-between; min-height: 68px; }
  .brand { display: inline-flex; align-items: center; gap: 0.65rem; text-decoration: none; color: var(--ink); }
  .brand-mark {
    font-family: var(--display); font-weight: 700; font-size: 0.95rem;
    background: var(--ink); color: var(--paper);
    width: 2rem; height: 2rem; display: grid; place-items: center; border-radius: 3px;
    letter-spacing: -0.03em;
  }
  .brand-name { font-family: var(--display); font-weight: 600; font-size: 1.15rem; letter-spacing: -0.01em; }

  .nav-desktop { display: none; gap: 0.3rem; }
  .nav-link {
    font-family: var(--body); font-size: 0.95rem; font-weight: 500;
    color: var(--charcoal); text-decoration: none; padding: 0.5rem 0.85rem; border-radius: 3px;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .nav-link:hover { color: var(--ink); background: color-mix(in srgb, var(--brass) 14%, transparent); }
  .nav-link.active { color: var(--ink); font-weight: 600; }

  /* Mobile */
  .nav-mobile { position: relative; }
  .nav-mobile summary {
    list-style: none; cursor: pointer; width: 2.4rem; height: 2.4rem;
    display: grid; place-content: center; gap: 5px;
  }
  .nav-mobile summary::-webkit-details-marker { display: none; }
  .nav-mobile summary span { display: block; width: 22px; height: 2px; background: var(--ink); transition: transform 0.2s; }
  .nav-mobile[open] summary span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-mobile[open] summary span:nth-child(2) { opacity: 0; }
  .nav-mobile[open] summary span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  .nav-mobile-panel {
    position: absolute; right: 0; top: calc(100% + 0.5rem);
    background: var(--paper-pure); border: 1px solid var(--cream-line); border-radius: var(--radius);
    box-shadow: 0 16px 40px -16px rgba(22,32,46,0.3);
    display: flex; flex-direction: column; padding: 0.5rem; min-width: 180px;
  }
  .nav-mobile-panel .nav-link { padding: 0.7rem 0.9rem; }

  @media (min-width: 880px) {
    .nav-desktop { display: flex; }
    .nav-mobile { display: none; }
  }
</style>
