---
const { eyebrow, title, lede } = Astro.props;
---
<section class="phead">
  <div class="wrap phead-inner">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="phead-title">{title}</h1>
    {lede && <p class="lede phead-lede">{lede}</p>}
    <slot />
  </div>
</section>

<style>
  .phead { padding-block: clamp(2.5rem, 6vw, 4.5rem) clamp(1.5rem, 3vw, 2.5rem); border-bottom: 1px solid var(--cream-line); }
  .phead-inner { max-width: 820px; }
  .phead-title { font-size: var(--step-3); margin-bottom: 1rem; }
  .phead-lede { max-width: 60ch; margin-bottom: 0; }
</style>
