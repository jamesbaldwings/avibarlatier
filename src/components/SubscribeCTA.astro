---
import { links, channelLive } from '../data/site.js';
import NewsletterForm from './NewsletterForm.astro';
const { variant = 'auto' } = Astro.props;
// variant: 'auto' uses channelLive; 'subscribe' forces YT; 'newsletter' forces email
const showSubscribe = variant === 'subscribe' || (variant === 'auto' && channelLive);
---
<section class="cta-band reveal">
  <div class="wrap cta-inner">
    {showSubscribe ? (
      <>
        <p class="eyebrow" style="color: var(--brass);">The channel</p>
        <h2 class="cta-title">New leadership lessons, every week.</h2>
        <p class="cta-sub">Short animated videos that turn one hard leadership moment into something you can actually use on Monday.</p>
        <div class="cta-actions">
          <a href={links.youtube} class="btn btn-primary" target="_blank" rel="noopener">Subscribe on YouTube</a>
          <a href={links.newsletter} class="btn btn-ghost" target="_blank" rel="noopener">Get the newsletter</a>
        </div>
      </>
    ) : (
      <>
        <img src="/img/humaneresources-logo.jpg" alt="Humane Resources" class="cta-logo" width="84" height="84" loading="lazy" />
        <p class="eyebrow" style="color: var(--brass);">Get it first</p>
        <h2 class="cta-title">The lessons land in your inbox before they hit YouTube.</h2>
        <p class="cta-sub">Join <em>Humane Resources</em> for practical leadership notes written for managers leading a new generation. The video channel launches soon, subscribers hear first.</p>
        <div class="cta-actions cta-form">
          <NewsletterForm dark={true} />
        </div>
      </>
    )}
  </div>
</section>

<style>
  .cta-band { background: var(--ink); color: var(--paper); padding-block: clamp(3.5rem, 7vw, 5.5rem); }
  .cta-inner { text-align: center; max-width: 720px; }
  .cta-title { color: var(--paper); font-size: var(--step-2); margin-inline: auto; max-width: 18ch; }
  .cta-sub { color: color-mix(in srgb, var(--paper) 82%, transparent); margin-inline: auto; font-size: var(--step-1); line-height: 1.45; }
  .cta-actions { display: flex; flex-wrap: wrap; gap: 0.8rem; justify-content: center; margin-top: 1.8rem; }
  .cta-logo { width: 84px; height: 84px; border-radius: 16px; margin: 0 auto 1.2rem; box-shadow: 0 14px 34px -18px rgba(0,0,0,0.6); }
</style>
