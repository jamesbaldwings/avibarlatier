---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import { links } from '../data/site.js';
const creds = [
  { t:'PMP — Project Management Professional', d:'Project Management Institute' },
  { t:'MBA, Information Technology Management', d:'Master of Business Administration' },
  { t:'Ph.D. in Cybersecurity', d:'National University — in progress' },
  { t:'Bachelor of Science in Business', d:'Undergraduate degree' },
  { t:'A.A.S. in Veterinary Technology', d:'Applied science foundation' },
];
---
<Base title="Credentials" description="Avi Barlatier's credentials: PMP, MBA in IT management, Ph.D. in cybersecurity in progress, and a foundation in veterinary technology.">
  <PageHeader eyebrow="Credentials" title="The paper behind the perspective."
    lede="Two decades of operational leadership, backed by formal training across business, technology, and security." />
  <section class="section"><div class="wrap">
    <ul class="cred-list">
      {creds.map((c)=>(
        <li class="cred">
          <span class="cred-mark" aria-hidden="true"></span>
          <div><h2>{c.t}</h2><p class="muted">{c.d}</p></div>
        </li>
      ))}
    </ul>
    <div class="badge-note">
      <h2>PMP credential</h2>
      <p class="muted">Verify the live PMP badge via Credly. Embed code drops in here once connected.</p>
      <a href={links.github} class="btn btn-outline" target="_blank" rel="noopener">View GitHub portfolio</a>
    </div>
  </div></section>
</Base>
<style>
  .cred-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; max-width: 720px; }
  .cred { display: flex; gap: 1rem; align-items: start; padding: 1.3rem 1.5rem; background: var(--paper-pure); border: 1px solid var(--cream-line); border-radius: var(--radius); }
  .cred-mark { width: 10px; height: 10px; border-radius: 50%; background: var(--brass); margin-top: 0.5rem; flex: none; }
  .cred h2 { font-size: var(--step-1); margin: 0 0 0.2rem; }
  .cred p { margin: 0; font-size: 0.9rem; }
  .badge-note { margin-top: 2.5rem; padding: 2rem; background: var(--ink); border-radius: var(--radius); }
  .badge-note h2 { color: var(--paper); font-size: var(--step-1); }
  .badge-note p { color: color-mix(in srgb, var(--paper) 78%, transparent); }
  .badge-note .btn { border-color: var(--brass); color: var(--brass); margin-top: 0.5rem; }
  .badge-note .btn:hover { background: var(--brass); color: var(--ink); }
</style>
