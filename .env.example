# Copy to .env for local dev (.env is gitignored). Set the same vars in Railway.

# Password for the /admin dashboard. Required for admin login to work.
ADMIN_PASSWORD=change-me

# Where the admin saves page-visibility state. In Railway, mount a Volume and
# point this at it (e.g. /data) so changes survive redeploys. Local dev can
# leave it unset (defaults to ./.data).
# DATA_DIR=/data

# Optional: hard-set the YouTube channel id to skip handle resolution.
# Already configured in src/data/site.js, so usually not needed.
# YT_CHANNEL_ID=UCHS2dtQMlNUxqUMD1LeiCfQ
